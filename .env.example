# Supabase Configuration
# Get these from your Supabase project settings at https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe Configuration (for Sunset Series Ticketing only)
# Get these from your Stripe dashboard at https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
# Webhook secret - get this after creating webhook endpoint in Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Ticket price in cents (e.g., 2000 = $20.00)
TICKET_PRICE=2000

# Venmo Configuration (for Donations)
# Your Venmo username (without the @ symbol)
VENMO_USERNAME=AllantQuartet

# Resend Email Configuration
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key
# Sender address for outbound mail. MUST be on a domain you've verified at
# https://resend.com/domains — otherwise the default sandbox sender is used,
# which only delivers to the Resend account owner (so customers won't get
# their confirmation emails).
RESEND_FROM_EMAIL="Allante String Quartet <noreply@yourdomain.com>"

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
ORGANIZATION_EMAIL=allantestringquartet@gmail.com
